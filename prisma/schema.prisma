generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model hotel {
  id                    Int      @id @default(autoincrement())
  nombre                String
  localizacion          String
  cantidad_habitaciones Int
  imagen_h              String?
  descripcion           String
  precio                Int?
  fecha_subido          DateTime @default(now())
  fecha_actualizado     DateTime @updatedAt
}

model Formulario {
  id                 Int      @id @default(autoincrement())
  nombre_completo    String
  gmail              String
  cantidad_huespedes Int
  llegada            DateTime @db.Date
  salida             DateTime @db.Date
  fecha_subido       DateTime @default(now())
  fecha_actualizado  DateTime @updatedAt
}
